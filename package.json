{
  "name": "playwright-e-commerce-foundation",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end Playwright test suite for an e-commerce site, built with TypeScript, the Page Object Model, and accessibility-first locators.",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e-testing",
    "page-object-model",
    "test-automation"
  ],
  "author": "Paul Yardley",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "dotenv": "^17.4.2",
    "eslint-plugin-playwright": "^2.10.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
